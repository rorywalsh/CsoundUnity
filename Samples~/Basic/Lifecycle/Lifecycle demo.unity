  _csoundFileGUID: afaa156295c84479fbfb7f4dc07e87ab
  _csoundString: "<Cabbage>\r\nform caption (\"Basic Test\"), size(300, 100)\r\n\r\nhslider
    bounds(0, 0, 300, 50) range(20, 16000, 440, 1, 0.001) valuetextbox(1) channel(\"freqSlider\")
    value(440) velocity(50)\r\n</Cabbage>\r\n\r\n<CsoundSynthesizer>\r\n<CsOptions>\r\n;-n
    -d -m0d \r\n;-odac\r\n-n ; -m0d\r\n</CsOptions>\r\n<CsInstruments> \r\nsr \t=
    \t48000 \r\nksmps \t= \t64\r\nnchnls \t= \t2\r\n0dbfs\t=\t1 \r\n\r\ninstr 1\r\na1
    oscil .2, chnget:k(\"freqSlider\"), 1\r\nouts a1, a1\r\n\r\nendin\r\n\r\n</CsInstruments>\r\n<CsScore>\r\nf1
    0 4096 10 1\r\ni1 0 5\r\n</CsScore>\r\n</CsoundSynthesizer>\r\n"
  _csoundFileName: BasicTest.csd
  _csoundAsset: {fileID: 102900000, guid: afaa156295c84479fbfb7f4dc07e87ab, type: 3}
