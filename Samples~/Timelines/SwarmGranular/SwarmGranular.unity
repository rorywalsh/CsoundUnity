    caption: 
    min: 0.001
    max: 0.5
    value: 0.01
    skew: 1
    increment: 0.001
    options: []
  - type: rslider
    channel: release
    text: Release
    caption: 
    min: 0.001
    max: 0.5
    value: 0.05
    skew: 1
    increment: 0.001
    options: []
  - type: rslider
