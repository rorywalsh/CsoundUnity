--- !u!114 &1917899497
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1917899496}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3d20258c641c94f0ea3dc32cfe3de904, type: 3}
  m_Name: 
  m_EditorClassIdentifier: com.csound.unity::Csound.Unity.CsoundUnity
  logCsoundOutput: 0
  mute: 0
  processClipAudio: 0
  loudVolumeWarning: 1
  loudWarningThreshold: 10
  overrideSamplingRate: 0
  audioRate: 44100
  controlRate: 44100
  updateOutputBuffer: 0
  csoundScore: 
  environmentSettings: []
  _csoundFileGUID: bdecf6d6f7bc14e558f5290f64183183
  _csoundString: "<Cabbage>\nform caption(\"Swarm Granular\") size(490, 200), guiMode(\"queue\"),
    pluginId(\"swgr\")\nrslider bounds(10,  10, 80, 80) channel(\"gain\")      range(0,
    1, 0.7, 1, 0.001) text(\"Master Gain\")\nrslider bounds(100, 10, 80, 80) channel(\"grainAmp\") 
    range(0, 0.2, 0.1, 1, 0.001) text(\"Grain Amp\")\nrslider bounds(190, 10, 80,
    80) channel(\"attack\")    range(0.001, 0.5, 0.01, 1, 0.001) text(\"Attack\")\nrslider
    bounds(280, 10, 80, 80) channel(\"release\")   range(0.001, 0.5, 0.05, 1, 0.001)
    text(\"Release\")\nrslider bounds(370, 10, 80, 80) channel(\"panSpread\") range(0,
    1, 0.5, 1, 0.01) text(\"Pan Spread\")\n</Cabbage>\n<CsoundSynthesizer>\n<CsOptions>\n-n
    -d\n</CsOptions>\n<CsInstruments>\n; Swarm Granular - each note event is a single
    grain\n; p4 = frequency in Hz (set by CsoundUnity SwarmRoutine with pitch randomization)\n;\n;
    Channels:\n;   gain      - master output gain (0-1)\n;   grainAmp  - per-grain
    amplitude (keep low to avoid clipping with many overlapping grains)\n;   attack   
    - grain attack time in seconds\n;   release   - grain release time in seconds\n;  
    panSpread - stereo spread of random pan (0 = center, 1 = full random)\n\nsr    
    = 48000\nksmps  = 32\nnchnls = 2\n0dbfs  = 1\n\ngiSine ftgen 1, 0, 4096, 10,
    1\n\ninstr 1\n    iFreq   = p4                         ; frequency sent by SwarmRoutine\n   
    iDur    = p3                         ; grain duration (note duration)\n    iGain  
    = chnget:i(\"gain\")\n    iAmp    = chnget:i(\"grainAmp\")       ; per-grain
    amplitude, keep low\n    iAtk    = chnget:i(\"attack\")\n    iRel    = chnget:i(\"release\")\n   
    iSpread = chnget:i(\"panSpread\")\n\n    ; Short grain envelope: attack + release,
    no sustain\n    aEnv    linen iAmp, iAtk, iDur, iRel\n\n    ; Oscillator at grain
    frequency\n    aGrain  oscili aEnv * iGain, iFreq, giSine\n\n    ; Random stereo
    pan per grain\n    iPan    random 0.5 - iSpread * 0.5, 0.5 + iSpread * 0.5\n   
    aL, aR  pan2 aGrain, iPan\n\n    outs aL, aR\nendin\n\n</CsInstruments>\n<CsScore>\n;
    Keep Csound running indefinitely - grains are triggered by score events from
    Unity\nf0 z\n</CsScore>\n</CsoundSynthesizer>\n"
  _csoundFileName: SwarmGranular.csd
  _csoundAsset: {fileID: 102900000, guid: bdecf6d6f7bc14e558f5290f64183183, type: 3}
  _channels:
  - type: form
    channel: 
    text: 
    caption: Swarm Granular
    min: 0
    max: 0
    value: 0
    skew: 0
    increment: 0
    options: []
  - type: rslider
