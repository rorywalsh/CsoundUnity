  _csoundString: "<Cabbage>\r\nform caption(\"Test Filling Bar\") size(400, 300),
    guiMode(\"queue\"), pluginId(\"fill\")\r\nhslider bounds(100, 124, 200, 50) channel(\"FillAmount\")
    range(0, 1, 0, 1, 0.001) velocity(0.84) valueTextBox(1)\r\nhslider bounds(100,
    174, 200, 50) channel(\"MinFrequency\") range(50, 2500, 440, 1, 0.001) valueTextBox(1)\r\nhslider
    bounds(100, 224, 200, 50) channel(\"MaxFrequency\") range(50, 2500, 880, 1, 0.001)
    valueTextBox(1)\r\n</Cabbage>\r\n<CsoundSynthesizer>\r\n<CsOptions>\r\n-n -d
    \r\n</CsOptions>\r\n<CsInstruments>\r\n; Initialize the global variables. \r\nnchnls
    = 2\r\n0dbfs = 1\r\n\r\n;instrument will be triggered by keyboard widget\r\ninstr
    1\r\n;kEnv adsr .1, .2, .6, .4\r\nkMinFreq = chnget:k(\"MinFrequency\")\r\nkMaxFreq
    = chnget:k(\"MaxFrequency\")\r\nkAmount = chnget:k(\"FillAmount\")\r\nkFreq init
    0.0001\r\nkFreq = kMinFreq + (kMaxFreq - kMinFreq) * kAmount\r\n;printks \"kAmount:
    %f - %f - %f\\n\", 0.1, kAmount, chnget:k(\"FillAmount\"), chnget:k(\"MaxFrequency\")\r\naEnv
    madsr 0.2, 0.1, 0.5, 0.1\r\naOut oscili aEnv, kFreq, 1\r\nouts aOut, aOut\r\nendin\r\n\r\n</CsInstruments>\r\n<CsScore>\r\n;causes
    Csound to run for about 7000 years...\r\nf0 z\r\n;i1 0 3600\r\nf1 0 4096 10 1\r\n</CsScore>\r\n</CsoundSynthesizer>\r\n"
