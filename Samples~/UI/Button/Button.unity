  loudVolumeWarning: 1
  loudWarningThreshold: 10
  overrideSamplingRate: 0
  audioRate: 44100
  controlRate: 44100
  updateOutputBuffer: 0
  csoundScore: 
  environmentSettings: []
  _csoundFileGUID: 43130ca37c94e4b39b0370ce59667da3
  _csoundString: "<Cabbage>\r\nform caption(\"TestButton\") size(150, 100), guiMode(\"queue\"),
    pluginId(\"btn1\")\r\nbutton bounds(10, 10, 80, 40) channel(\"trigger\") text(\"Push
    Me\")\r\n</Cabbage>\r\n<CsoundSynthesizer>\r\n<CsOptions>\r\n-n -d\r\n</CsOptions>\r\n<CsInstruments>\r\n;
    Initialize the global variables. \r\nksmps = 32\r\nnchnls = 2\r\n0dbfs = 1\r\n\r\n;instrument
    will be triggered by score sent by Unity UI button\r\ninstr 1\r\nkEnv madsr .1,
    .2, .6, .4\r\naOut vco2 0.5, 440\r\nouts aOut*kEnv, aOut*kEnv\r\nendin\r\n\r\ninstr
    2\r\nkTrig init 0\r\nkTrig = chnget:k(\"trigger\")\r\nkChanged changed kTrig\r\n\r\nprintk2
    kTrig\r\n\r\nif (kTrig == 1 && kChanged == 1) then\r\n   kTrig = 0\r\n   chnset(kTrig,
    \"trigger\")\r\n   schedulek 1, 0, 3\r\nendif\r\n\r\nendin\r\n\r\n</CsInstruments>\r\n<CsScore>\r\n;causes
    Csound to run for about 7000 years...\r\nf0 z\r\ni2 0 z\r\n</CsScore>\r\n</CsoundSynthesizer>\r\n"
  _csoundFileName: Button.csd
  _csoundAsset: {fileID: 102900000, guid: 43130ca37c94e4b39b0370ce59667da3, type: 3}
  _channels:
  - type: form
    channel: 
    text: 
    caption: TestButton
    min: 0
    max: 0
    value: 0
    skew: 0
    increment: 0
    options: []
    channelY: 
    minY: 0
    maxY: 0
    value2: 0
  - type: button
    channel: trigger
    text: Push Me
    caption: 
    min: 0
    max: 0
    value: 0
    skew: 0
    increment: 0
    options: []
    channelY: 
