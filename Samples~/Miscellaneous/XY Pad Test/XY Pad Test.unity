MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1395525323}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 3d20258c641c94f0ea3dc32cfe3de904, type: 3}
  m_Name: 
  m_EditorClassIdentifier: com.csound.unity::Csound.Unity.CsoundUnity
  logCsoundOutput: 1
  mute: 0
  processClipAudio: 0
  loudVolumeWarning: 1
  loudWarningThreshold: 10
  overrideSamplingRate: 0
  audioRate: 44100
  controlRate: 4410
  updateOutputBuffer: 0
  csoundScore: 
  environmentSettings: []
  _csoundFileGUID: 0c98aff8dea2949a68ad252d6d1a842d
  _csoundString: "<Cabbage>\r\nform caption(\"XYPad Example\") size(400, 350), guiMode(\"queue\"),
    colour(2, 145, 209) pluginId(\"def1\")\r\nxypad bounds(26, 20, 260, 250) channel(\"x\",
    \"y\") rangeX(20, 800, 105) rangeY(20, 800, 200)\r\nrslider bounds(300, 190,
    73, 71) channel(\"gain\") textColour(255, 255, 255, 255), text(\"Gain\") range(0,
    2, 1.158, 1, 0.001)\r\nrslider bounds(300, 32, 73, 71) channel(\"wetDry\") textColour(255,
    255, 255, 255), text(\"Wet/Dry\") range(0, 1, 0, 1, 0.001)\r\n</Cabbage>\r\n<CsoundSynthesizer>\r\n<CsOptions>\r\n-n
    -d\r\n</CsOptions>e\r\n<CsInstruments>\r\n; Initialize the global variables.
    \r\nksmps = 16\r\nnchnls = 2\r\n0dbfs = 1\r\n\r\n; Rory Walsh 2021 \r\n; ported
    to CsoundUnity by gb 2026\r\n;\r\n; License: CC0 1.0 Universal\r\n; You can copy,
    modify, and distribute this work, \r\n; even for commercial purposes, all without
    asking permission. \r\n\r\ninstr 1\r\n\r\n    kX = chnget:k(\"x\")\r\n    kY
    = chnget:k(\"y\")\r\n    kSpeed = chnget:k(\"speed\")\r\n\r\n    aMod oscili
    1, kX\r\n    aCar oscili aMod, kY\r\n\r\n    aDryL vco2 0.6, kX\r\n    aDryR
    vco2 0.6, kY \r\n    aDelL comb aDryL, 5, 0.25\r\n    aDelR comb aDryR, 5, 0.75\r\n\r\n   
    aPan jspline 1, .1, .5\r\n\r\n    aWetL, aWetR reverbsc (aDelL*aCar)*aPan, (aDelR*aCar)*(1-aPan),
    .7, 1000\r\n\r\n    aL ntrpol aWetL, aDryL, chnget:k(\"wetDry\")\r\n    aR ntrpol
    aWetR, aDryR, chnget:k(\"wetDry\")\r\n\r\n    outs aL*chnget:k(\"gain\"), aR*chnget:k(\"gain\")\r\n\r\n\r\nendin\r\n\r\n</CsInstruments>\r\n<CsScore>\r\n;causes
    Csound to run for about 7000 years...\r\nf0 z\r\n;starts instrument 1 and runs
    it for a week\r\ni1 0 z\r\n</CsScore>\r\n</CsoundSynthesizer>"
  _csoundFileName: XY Pad Test.csd
  _csoundAsset: {fileID: 102900000, guid: 0c98aff8dea2949a68ad252d6d1a842d, type: 3}
  _channels:
  - type: form
    channel: 
    text: 
    caption: XYPad Example
    min: 0
    max: 0
    value: 0
    skew: 0
    increment: 0
    options: []
    value2: 0
  - type: xypad
    channel: x
    text: 
    caption: y
    min: 20
    max: 800
    value: 105
    skew: 20
    increment: 800
    options: []
    value2: 200
  - type: rslider
    channel: gain
    text: Gain
    caption: 
    min: 0
    max: 2
    value: 1.158
    skew: 1
    increment: 0.001
    options: []
    value2: 0
  - type: rslider
    channel: wetDry
    text: Wet/Dry
    caption: 
    min: 0
    max: 1
    value: 0
    skew: 1
    increment: 0.001
    options: []
    value2: 0
  _availableAudioChannels: []
  _audioChannelsToAdd: []
  _audioChannelsToRemove: []
  _audioChannelsBufferSize: 32
  _drawCsoundString: 0
  _drawTestScore: 0
  _drawSettings: 1
